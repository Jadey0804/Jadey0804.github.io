---
import SiteLayout from '../layouts/SiteLayout.astro';
import BilibiliPlayer from '../components/BilibiliPlayer.astro';

const capabilities = [
  'UE5 gameplay systems',
  'C++ & Blueprints',
  'Level scripting',
  'Puzzle design',
  'Rapid prototyping',
  'Playtest iteration',
];
---

<SiteLayout>
  <section class="hero hero-minimal section-pad">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow"><span class="live-dot"></span> Open to gameplay & level design roles</p>
      <dl class="hero-meta">
        <div>
          <dt>Focus</dt>
          <dd>Gameplay / Level Design</dd>
        </div>
        <div>
          <dt>Tools</dt>
          <dd>UE5 · C++ · Blueprint</dd>
        </div>
        <div>
          <dt>Based</dt>
          <dd>United Kingdom</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="reel-section section-pad" aria-labelledby="reel-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">01 / SHOWREEL</p>
      <div>
        <h2 id="reel-title">See the work in motion.</h2>
        <p>The final portfolio can play Bilibili videos directly without sending recruiters to another tab.</p>
      </div>
    </div>
    <div class="reel-layout" data-reveal>
      <div>
        <BilibiliPlayer
          bvid="BV1mfTW6vESe"
          title="Bilibili video embed demo: UE5 whitebox workflow"
        />
        <p class="media-credit">
          Demo embed using an external UE5 whitebox reference video. Replace one <code>bvid</code> with your own reel later.
        </p>
      </div>
      <aside class="reel-notes">
        <p class="mini-label">Embed prototype</p>
        <h3>Native Bilibili playback</h3>
        <p>
          Responsive 16:9 player, fullscreen support, lazy loading, and no custom video hosting required.
        </p>
        <ul class="feature-list">
          <li><span>01</span> Plays inside the case study</li>
          <li><span>02</span> Works on desktop and mobile</li>
          <li><span>03</span> Replaceable via a single BVID</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="work" class="work-section section-pad" aria-labelledby="work-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">02 / SELECTED WORK</p>
      <div>
        <h2 id="work-title">A focused set of playable proof.</h2>
        <p>Three projects, each proving a different part of the craft.</p>
      </div>
    </div>

    <div class="project-grid">
      <article class="project-card project-featured" data-reveal>
        <a class="project-visual ocean-visual" href="/projects/sunken-city/" aria-label="Open Sunken City case study">
          <div class="visual-grid"></div>
          <svg viewBox="0 0 800 520" aria-hidden="true">
            <path d="M92 346c77-84 112-163 210-170 76-6 105 54 173 26 85-35 139 31 229 119" />
            <path d="M74 397c93-69 188-45 248-111 58-64 106-3 160 9 77 18 138 40 247 109" />
            <circle cx="306" cy="223" r="40" />
            <circle cx="556" cy="278" r="24" />
          </svg>
          <div class="visual-tag">FEATURED CASE STUDY</div>
          <div class="visual-title">SUNKEN<br />CITY</div>
          <div class="visual-coordinate">UE5 / 5.4.4</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>Gameplay systems · Level design</p>
            <span>2026</span>
          </div>
          <h3><a href="/projects/sunken-city/">Sunken City</a></h3>
          <p>
            A third-person underwater exploration game combining traversal, oxygen pressure,
            systemic interaction, environmental puzzles, and fish-school AI.
          </p>
          <ul class="tag-list">
            <li>Unreal Engine 5</li>
            <li>C++</li>
            <li>Blueprint</li>
            <li>Puzzle design</li>
          </ul>
          <a class="text-link" href="/projects/sunken-city/">Read the case study <span>↗</span></a>
        </div>
      </article>

      <article class="project-card" data-reveal>
        <a
          class="project-visual render-visual"
          href="https://github.com/Jadey0804/Rasterizer---2026"
          target="_blank"
          rel="noreferrer"
          aria-label="Open Rasterizer repository"
        >
          <div class="visual-grid"></div>
          <div class="wire-cube" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
          <div class="visual-tag">GRAPHICS PROGRAMMING</div>
          <div class="visual-title">SOFTWARE<br />RASTERIZER</div>
          <div class="visual-coordinate">C++ / CPU</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>Rendering · Performance</p>
            <span>2026</span>
          </div>
          <h3>Software Rasterizer</h3>
          <p>A CPU rendering pipeline built to make transforms, clipping, shading, and optimisation tangible.</p>
          <ul class="tag-list"><li>C++</li><li>Rendering</li><li>Multithreading</li></ul>
          <a class="text-link" href="https://github.com/Jadey0804/Rasterizer---2026" target="_blank" rel="noreferrer">View repository <span>↗</span></a>
        </div>
      </article>

      <article class="project-card" data-reveal>
        <a
          class="project-visual ray-visual"
          href="https://github.com/Jadey0804/RTBase-main"
          target="_blank"
          rel="noreferrer"
          aria-label="Open RTBase repository"
        >
          <div class="visual-grid"></div>
          <div class="ray-orbit" aria-hidden="true"><i></i><i></i><i></i></div>
          <div class="visual-tag">RENDERING STUDY</div>
          <div class="visual-title">RAY<br />TRACING LAB</div>
          <div class="visual-coordinate">LIGHT / MATERIAL</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>Graphics · Technical study</p>
            <span>2026</span>
          </div>
          <h3>Ray Tracing Lab</h3>
          <p>A focused study of sampling, materials, lighting, and scene representation inside a teaching framework.</p>
          <ul class="tag-list"><li>C++</li><li>Monte Carlo</li><li>Materials</li></ul>
          <a class="text-link" href="https://github.com/Jadey0804/RTBase-main" target="_blank" rel="noreferrer">View repository <span>↗</span></a>
        </div>
      </article>
    </div>
  </section>

  <section class="notes-section section-pad" aria-labelledby="notes-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">03 / DESIGN NOTES</p>
      <div>
        <h2 id="notes-title">Show the thinking, not only the finish.</h2>
        <p>Short breakdowns turn design decisions into evidence.</p>
      </div>
    </div>
    <div class="notes-grid">
      <a class="note-card note-card-featured" href="/analysis/player-guidance/" data-reveal>
        <div class="note-number">01</div>
        <div>
          <p class="mini-label">Level design · 6 min read</p>
          <h3>Teaching underwater movement without another tutorial popup</h3>
          <p>Using safe spaces, framing, landmarks, and escalating pressure to let the level do the teaching.</p>
        </div>
        <span class="note-arrow">↗</span>
      </a>
      <a class="note-card" href="/analysis/" data-reveal>
        <div class="note-number">02</div>
        <div>
          <p class="mini-label">Puzzle design · Draft</p>
          <h3>Building a readable counterweight puzzle</h3>
          <p>From dependency diagram to blockout and playtest checkpoints.</p>
        </div>
        <span class="note-arrow">↗</span>
      </a>
      <a class="note-card" href="/analysis/" data-reveal>
        <div class="note-number">03</div>
        <div>
          <p class="mini-label">Technical design · Draft</p>
          <h3>One interaction language, many gameplay objects</h3>
          <p>Keeping the player-facing rule simple while the implementation stays extensible.</p>
        </div>
        <span class="note-arrow">↗</span>
      </a>
    </div>
  </section>

  <section id="about" class="about-section section-pad" aria-labelledby="about-title">
    <div class="about-copy" data-reveal>
      <p class="section-index">04 / ABOUT</p>
      <h2 id="about-title">A designer who can follow an idea into the engine.</h2>
      <p>
        I enjoy the space between design and implementation: prototyping a rule, putting it in front
        of players, learning where it breaks, and shaping both the system and the level around what the
        playtest reveals.
      </p>
      <a class="text-link" href="mailto:hello@example.com">Start a conversation <span>↗</span></a>
    </div>
    <div class="capability-panel" data-reveal>
      <p class="mini-label">Capabilities</p>
      <ul>
        {capabilities.map((capability, index) => (
          <li><span>{String(index + 1).padStart(2, '0')}</span>{capability}</li>
        ))}
      </ul>
    </div>
  </section>
</SiteLayout>
