---
import SiteLayout from '../../layouts/SiteLayout.astro';
import BilibiliPlayer from '../../components/BilibiliPlayer.astro';

const capabilities = [
  'UE5 玩法系统',
  'C++ 与蓝图',
  '关卡脚本',
  '谜题设计',
  '快速原型',
  '测试与迭代',
];
---

<SiteLayout
  title="Jadey — 技术游戏设计与玩法程序开发"
  description="Jadey 的个人作品集，聚焦 Unreal Engine 5、玩法系统、关卡设计与技术游戏设计。"
>
  <section class="hero section-pad">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow"><span class="live-dot"></span> 正在寻找玩法开发与关卡设计机会</p>
      <h1>
        我构建<span>有手感的系统</span>，也设计让玩家在游玩中理解规则的关卡。
      </h1>
      <p class="hero-intro">
        技术游戏设计师与玩法程序开发，使用 Unreal Engine 5，连接面向玩家的系统、易读的空间与快速迭代。
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="#work">查看精选项目</a>
        <a class="button button-quiet" href="/zh/projects/sunken-city/">查看案例 <span>→</span></a>
      </div>
      <dl class="hero-meta">
        <div>
          <dt>方向</dt>
          <dd>玩法开发 / 关卡设计</dd>
        </div>
        <div>
          <dt>工具</dt>
          <dd>UE5 · C++ · Blueprint</dd>
        </div>
        <div>
          <dt>所在地</dt>
          <dd>英国</dd>
        </div>
      </dl>
    </div>

    <div class="hero-map" data-reveal aria-label="俯视关卡流程示意图">
      <div class="map-toolbar">
        <div class="window-dots" aria-hidden="true"><i></i><i></i><i></i></div>
        <span>LEVEL_FLOW / 01</span>
        <span>PLAYTEST_07</span>
      </div>
      <div class="map-canvas">
        <svg viewBox="0 0 660 640" role="img" aria-labelledby="map-title map-description">
          <title id="map-title">俯视谜题关卡流程</title>
          <desc id="map-description">路线从新手教学进入探索循环，经过谜题门，最终抵达奖励。</desc>
          <defs>
            <pattern id="grid" width="28" height="28" patternUnits="userSpaceOnUse">
              <path d="M28 0H0V28" fill="none" stroke="currentColor" stroke-opacity=".08" />
            </pattern>
            <linearGradient id="route" x1="0" y1="0" x2="1" y2="1">
              <stop stop-color="#c9ff38" />
              <stop offset="1" stop-color="#67a6ff" />
            </linearGradient>
          </defs>
          <rect width="660" height="640" fill="url(#grid)" />
          <path class="map-zone" d="M68 475 174 390l118 22 49 98-61 80-141-5Z" />
          <path class="map-zone" d="M245 215 376 138l152 44 32 133-89 80-168-35Z" />
          <path class="map-zone map-zone-focus" d="m383 432 111-37 91 68-31 108-137 18-56-82Z" />
          <path class="map-route-shadow" d="M114 528c84-3 72-92 151-92 65 0 36-179 118-193 78-13 86 91 124 122 36 30-16 84-54 120" />
          <path class="map-route" d="M114 528c84-3 72-92 151-92 65 0 36-179 118-193 78-13 86 91 124 122 36 30-16 84-54 120" />
          <circle class="map-node map-node-start" cx="114" cy="528" r="14" />
          <circle class="map-node" cx="266" cy="436" r="11" />
          <circle class="map-node" cx="383" cy="243" r="11" />
          <circle class="map-node map-node-gate" cx="507" cy="365" r="16" />
          <circle class="map-node map-node-end" cx="453" cy="485" r="14" />
          <path class="sightline" d="m381 243 127 122M381 243l83-69M507 365l86-76" />
        </svg>
        <div class="map-label label-entry"><span>01</span> 新手教学</div>
        <div class="map-label label-loop"><span>02</span> 探索循环</div>
        <div class="map-label label-gate"><span>03</span> 谜题门</div>
        <div class="map-label label-reward"><span>04</span> 奖励</div>
        <div class="map-readout">
          <span>关键路径</span>
          <strong>04:20</strong>
          <span>可选空间</span>
          <strong>38%</strong>
        </div>
      </div>
      <div class="map-caption">
        <p>设计意图</p>
        <p>教学 → 测试 → 重组</p>
      </div>
    </div>
  </section>

  <section class="reel-section section-pad" aria-labelledby="reel-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">01 / 实机展示</p>
      <div>
        <h2 id="reel-title">让作品动起来。</h2>
        <p>作品集可以直接播放 Bilibili 视频，无需让招聘者跳转到新页面。</p>
      </div>
    </div>
    <div class="reel-layout" data-reveal>
      <div>
        <BilibiliPlayer
          bvid="BV1mfTW6vESe"
          title="Bilibili 视频嵌入演示：UE5 白盒工作流"
        />
        <p class="media-credit">
          当前使用外部 UE5 白盒参考视频演示。之后只需替换一个 <code>bvid</code> 即可使用你自己的展示视频。
        </p>
      </div>
      <aside class="reel-notes">
        <p class="mini-label">嵌入原型</p>
        <h3>直接播放 Bilibili 视频</h3>
        <p>响应式 16:9 播放器，支持全屏与延迟加载，不需要自行托管视频。</p>
        <ul class="feature-list">
          <li><span>01</span> 在案例页面内直接播放</li>
          <li><span>02</span> 支持桌面端与移动端</li>
          <li><span>03</span> 只需替换一个 BVID</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="work" class="work-section section-pad" aria-labelledby="work-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">02 / 精选项目</p>
      <div>
        <h2 id="work-title">用可玩的成果证明能力。</h2>
        <p>三个项目，分别展示不同的设计与开发能力。</p>
      </div>
    </div>

    <div class="project-grid">
      <article class="project-card project-featured" data-reveal>
        <a class="project-visual ocean-visual" href="/zh/projects/sunken-city/" aria-label="打开沉没之城项目案例">
          <div class="visual-grid"></div>
          <svg viewBox="0 0 800 520" aria-hidden="true">
            <path d="M92 346c77-84 112-163 210-170 76-6 105 54 173 26 85-35 139 31 229 119" />
            <path d="M74 397c93-69 188-45 248-111 58-64 106-3 160 9 77 18 138 40 247 109" />
            <circle cx="306" cy="223" r="40" />
            <circle cx="556" cy="278" r="24" />
          </svg>
          <div class="visual-tag">重点项目案例</div>
          <div class="visual-title">SUNKEN<br />CITY</div>
          <div class="visual-coordinate">UE5 / 5.4.4</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>玩法系统 · 关卡设计</p>
            <span>2026</span>
          </div>
          <h3><a href="/zh/projects/sunken-city/">沉没之城</a></h3>
          <p>一款第三人称水下探索游戏，结合移动、氧气压力、系统性交互、环境谜题与鱼群 AI。</p>
          <ul class="tag-list">
            <li>Unreal Engine 5</li>
            <li>C++</li>
            <li>Blueprint</li>
            <li>谜题设计</li>
          </ul>
          <a class="text-link" href="/zh/projects/sunken-city/">阅读项目案例 <span>→</span></a>
        </div>
      </article>

      <article class="project-card" data-reveal>
        <a
          class="project-visual render-visual"
          href="https://github.com/Jadey0804/Rasterizer---2026"
          target="_blank"
          rel="noreferrer"
          aria-label="打开光栅化渲染器代码仓库"
        >
          <div class="visual-grid"></div>
          <div class="wire-cube" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
          <div class="visual-tag">图形学编程</div>
          <div class="visual-title">SOFTWARE<br />RASTERIZER</div>
          <div class="visual-coordinate">C++ / CPU</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>渲染 · 性能</p>
            <span>2026</span>
          </div>
          <h3>软件光栅化渲染器</h3>
          <p>在 CPU 上搭建渲染管线，深入理解变换、裁剪、着色与性能优化。</p>
          <ul class="tag-list"><li>C++</li><li>渲染</li><li>多线程</li></ul>
          <a class="text-link" href="https://github.com/Jadey0804/Rasterizer---2026" target="_blank" rel="noreferrer">查看代码仓库 <span>→</span></a>
        </div>
      </article>

      <article class="project-card" data-reveal>
        <a
          class="project-visual ray-visual"
          href="https://github.com/Jadey0804/RTBase-main"
          target="_blank"
          rel="noreferrer"
          aria-label="打开光线追踪实验代码仓库"
        >
          <div class="visual-grid"></div>
          <div class="ray-orbit" aria-hidden="true"><i></i><i></i><i></i></div>
          <div class="visual-tag">渲染研究</div>
          <div class="visual-title">RAY<br />TRACING LAB</div>
          <div class="visual-coordinate">LIGHT / MATERIAL</div>
        </a>
        <div class="project-body">
          <div class="project-topline">
            <p>图形学 · 技术研究</p>
            <span>2026</span>
          </div>
          <h3>光线追踪实验</h3>
          <p>基于教学框架，对采样、材质、光照与场景表达进行集中研究。</p>
          <ul class="tag-list"><li>C++</li><li>Monte Carlo</li><li>材质</li></ul>
          <a class="text-link" href="https://github.com/Jadey0804/RTBase-main" target="_blank" rel="noreferrer">查看代码仓库 <span>→</span></a>
        </div>
      </article>
    </div>
  </section>

  <section class="notes-section section-pad" aria-labelledby="notes-title">
    <div class="section-heading" data-reveal>
      <p class="section-index">03 / 设计笔记</p>
      <div>
        <h2 id="notes-title">展示思考过程，而不只是最终结果。</h2>
        <p>用简短拆解，把设计决策转化为可见证据。</p>
      </div>
    </div>
    <div class="notes-grid">
      <a class="note-card note-card-featured" href="/zh/analysis/player-guidance/" data-reveal>
        <div class="note-number">01</div>
        <div>
          <p class="mini-label">关卡设计 · 阅读约 6 分钟</p>
          <h3>不依赖教学弹窗，如何教会玩家水下移动</h3>
          <p>通过安全空间、构图、地标与逐步增加的压力，让关卡本身完成教学。</p>
        </div>
        <span class="note-arrow">→</span>
      </a>
      <a class="note-card" href="/zh/analysis/" data-reveal>
        <div class="note-number">02</div>
        <div>
          <p class="mini-label">谜题设计 · 草稿</p>
          <h3>构建易读的配重谜题</h3>
          <p>从依赖关系图到白盒，再到游戏测试检查点。</p>
        </div>
        <span class="note-arrow">→</span>
      </a>
      <a class="note-card" href="/zh/analysis/" data-reveal>
        <div class="note-number">03</div>
        <div>
          <p class="mini-label">技术设计 · 草稿</p>
          <h3>一套交互语言，多种玩法对象</h3>
          <p>保持面向玩家的规则简单，同时让实现具有扩展性。</p>
        </div>
        <span class="note-arrow">→</span>
      </a>
    </div>
  </section>

  <section id="about" class="about-section section-pad" aria-labelledby="about-title">
    <div class="about-copy" data-reveal>
      <p class="section-index">04 / 关于</p>
      <h2 id="about-title">一名能把设计想法真正带进引擎的开发者。</h2>
      <p>
        我喜欢设计与实现之间的空间：快速验证规则，让玩家亲自体验，观察问题在哪里发生，再根据测试结果同时调整系统与关卡。
      </p>
      <a class="text-link" href="mailto:hello@example.com">与我联系 <span>→</span></a>
    </div>
    <div class="capability-panel" data-reveal>
      <p class="mini-label">能力方向</p>
      <ul>
        {capabilities.map((capability, index) => (
          <li><span>{String(index + 1).padStart(2, '0')}</span>{capability}</li>
        ))}
      </ul>
    </div>
  </section>
</SiteLayout>
