---
import AboutSection from './AboutSection.astro';

interface Props {
  locale: 'en' | 'zh';
}

const { locale } = Astro.props;
const isZh = locale === 'zh';
const copy = isZh
  ? {
      eyebrow: '游戏客户端开发作品集',
      title: 'UE5、C++ 与工具开发。',
      intro: '用可运行的代码、图形学实验与技术拆解，展示从底层原理到游戏功能实现的开发能力。',
      focus: '方向',
      focusValue: '客户端开发 / 玩法程序',
      tools: '工具',
      toolsValue: 'UE5 · C++ · Blueprint',
      workIndex: '01 / 程序项目',
      workTitle: '用实现结果证明技术基础。',
      workDescription: '当前集中展示两项 C++ 图形学项目，后续补充 UE5 客户端与工具案例。',
      rasterType: '渲染 · 性能',
      rasterTitle: '软件光栅化渲染器',
      rasterBody: '在 CPU 上搭建渲染管线，理解变换、裁剪、着色与性能优化。',
      rayType: '图形学 · 技术研究',
      rayTitle: '光线追踪实验',
      rayBody: '基于教学框架，对采样、材质、光照与场景表达进行集中研究。',
      repoLink: '查看代码仓库',
      notesIndex: '02 / 技术笔记',
      notesTitle: '记录实现路径与技术判断。',
      notesDescription: '暂以现有项目为入口，后续补充完整的技术文章与性能数据。',
      notes: [
        ['渲染管线 · 项目拆解', '从顶点变换到 CPU 光栅器', '围绕坐标变换、裁剪、光栅化与着色组织实现步骤。'],
        ['光线追踪 · 项目拆解', '采样、材质与光照如何协同', '围绕基础采样、材质响应与场景光照整理实验结果。'],
      ],
    }
  : {
      eyebrow: 'Client Development Portfolio',
      title: 'UE5, C++, and tool development.',
      intro: 'Runnable code, graphics experiments, and technical breakdowns show the path from fundamentals to practical game features.',
      focus: 'Focus',
      focusValue: 'Client / Gameplay Development',
      tools: 'Tools',
      toolsValue: 'UE5 · C++ · Blueprint',
      workIndex: '01 / DEVELOPMENT PROJECTS',
      workTitle: 'Implementation as evidence of technical fundamentals.',
      workDescription: 'The current set starts with two C++ graphics projects; UE5 client and tooling case studies will follow.',
      rasterType: 'Rendering · Performance',
      rasterTitle: 'Software Rasterizer',
      rasterBody: 'A CPU rendering pipeline built to make transforms, clipping, shading, and optimisation tangible.',
      rayType: 'Graphics · Technical study',
      rayTitle: 'Ray Tracing Lab',
      rayBody: 'A focused study of sampling, materials, lighting, and scene representation inside a teaching framework.',
      repoLink: 'View repository',
      notesIndex: '02 / TECHNICAL NOTES',
      notesTitle: 'Document the implementation path and technical choices.',
      notesDescription: 'Existing repositories are the starting point; full technical articles and performance data will follow.',
      notes: [
        ['Rendering pipeline · Project breakdown', 'From transformed vertices to a CPU rasterizer', 'Transforms, clipping, rasterisation, and shading organised as an implementation path.'],
        ['Ray tracing · Project breakdown', 'How sampling, materials, and lighting work together', 'An experiment-led view of basic sampling, material response, and scene lighting.'],
      ],
    };

const projects = [
  {
    kind: 'render',
    href: 'https://github.com/Jadey0804/Rasterizer---2026',
    label: isZh ? '图形学编程' : 'Graphics programming',
    visualTitle: 'SOFTWARE\nRASTERIZER',
    coordinate: 'C++ / CPU',
    type: copy.rasterType,
    title: copy.rasterTitle,
    body: copy.rasterBody,
    tags: ['C++', isZh ? '渲染' : 'Rendering', isZh ? '多线程' : 'Multithreading'],
  },
  {
    kind: 'ray',
    href: 'https://github.com/Jadey0804/RTBase-main',
    label: isZh ? '渲染研究' : 'Rendering study',
    visualTitle: 'RAY\nTRACING LAB',
    coordinate: 'LIGHT / MATERIAL',
    type: copy.rayType,
    title: copy.rayTitle,
    body: copy.rayBody,
    tags: ['C++', 'Monte Carlo', isZh ? '材质' : 'Materials'],
  },
];
---

<section class="direction-hero direction-client section-pad">
  <div data-reveal>
    <p class="eyebrow"><span class="live-dot"></span>{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p class="direction-intro">{copy.intro}</p>
    <dl class="hero-meta">
      <div><dt>{copy.focus}</dt><dd>{copy.focusValue}</dd></div>
      <div><dt>{copy.tools}</dt><dd>{copy.toolsValue}</dd></div>
    </dl>
  </div>
</section>

<section id="work" class="work-section section-pad" aria-labelledby="client-work-title">
  <div class="section-heading" data-reveal>
    <p class="section-index">{copy.workIndex}</p>
    <div><h2 id="client-work-title">{copy.workTitle}</h2><p>{copy.workDescription}</p></div>
  </div>
  <div class="project-grid">
    {projects.map((project) => (
      <article class="project-card" data-reveal>
        <a class:list={['project-visual', project.kind === 'render' ? 'render-visual' : 'ray-visual']} href={project.href} target="_blank" rel="noreferrer" aria-label={project.title}>
          <div class="visual-grid"></div>
          {project.kind === 'render'
            ? <div class="wire-cube" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
            : <div class="ray-orbit" aria-hidden="true"><i></i><i></i><i></i></div>}
          <div class="visual-tag">{project.label}</div>
          <div class="visual-title">{project.visualTitle.split('\n').map((line) => <>{line}<br /></>)}</div>
          <div class="visual-coordinate">{project.coordinate}</div>
        </a>
        <div class="project-body">
          <div class="project-topline"><p>{project.type}</p><span>2026</span></div>
          <h3>{project.title}</h3>
          <p>{project.body}</p>
          <ul class="tag-list">{project.tags.map((tag) => <li>{tag}</li>)}</ul>
          <a class="text-link" href={project.href} target="_blank" rel="noreferrer">{copy.repoLink} <span>↗</span></a>
        </div>
      </article>
    ))}
  </div>
</section>

<section id="notes" class="notes-section section-pad" aria-labelledby="client-notes-title">
  <div class="section-heading" data-reveal>
    <p class="section-index">{copy.notesIndex}</p>
    <div><h2 id="client-notes-title">{copy.notesTitle}</h2><p>{copy.notesDescription}</p></div>
  </div>
  <div class="notes-grid">
    {copy.notes.map((note, index) => (
      <a class="note-card" href={projects[index].href} target="_blank" rel="noreferrer" data-reveal>
        <div class="note-number">{String(index + 1).padStart(2, '0')}</div>
        <div><p class="mini-label">{note[0]}</p><h3>{note[1]}</h3><p>{note[2]}</p></div>
        <span class="note-arrow">↗</span>
      </a>
    ))}
  </div>
</section>

<AboutSection locale={locale} context="client" />
