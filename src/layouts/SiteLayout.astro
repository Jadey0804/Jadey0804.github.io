---
import SiteNav from '../components/SiteNav.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jadey — Technical Game Designer & Gameplay Programmer',
  description = 'Portfolio of Jadey, a technical game designer and gameplay programmer focused on Unreal Engine, gameplay systems, and level design.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const isZh = Astro.url.pathname === '/zh/' || Astro.url.pathname.startsWith('/zh/');
const lang = isZh ? 'zh-CN' : 'en';
const base = isZh ? '/zh' : '';
const isLegacyDesignRoute =
  Astro.url.pathname.startsWith(`${base}/analysis`) || Astro.url.pathname.startsWith(`${base}/projects`);
const direction = Astro.url.pathname.startsWith(`${base}/client`)
  ? 'client'
  : Astro.url.pathname.startsWith(`${base}/design`) || isLegacyDesignRoute
    ? 'design'
    : null;
const switchHref = direction === 'design' ? `${base}/client/` : `${base}/design/`;
const switchLabel = direction === 'design'
  ? isZh ? '查看客户端开发作品集' : 'View client development portfolio'
  : isZh ? '查看玩法策划作品集' : 'View gameplay design portfolio';
const isNotFound = Astro.url.pathname === '/404' || Astro.url.pathname === '/404/' || Astro.url.pathname === '/404.html';
const englishPath = isNotFound ? '/' : isZh ? Astro.url.pathname.replace(/^\/zh/, '') || '/' : Astro.url.pathname;
const chinesePath = isNotFound ? '/zh/' : isZh ? Astro.url.pathname : `/zh${Astro.url.pathname}`;
const englishUrl = new URL(englishPath, Astro.site);
const chineseUrl = new URL(chinesePath, Astro.site);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080b0e" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="zh-CN" href={chineseUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{isZh ? '跳到主要内容' : 'Skip to content'}</a>
    <div class="site-shell">
      <SiteNav />
      <main id="main-content">
        <slot />
      </main>
      {direction && (
        <aside class="direction-switch section-pad" aria-label={isZh ? '切换作品集方向' : 'Switch portfolio direction'}>
          <span>{isZh ? '切换作品集方向' : 'Switch portfolio direction'}</span>
          <a href={switchHref}>{switchLabel} <span aria-hidden="true">↗</span></a>
        </aside>
      )}
      <footer class="site-footer">
        <div>
          <span class="footer-mark" aria-hidden="true"></span>
          {isZh ? '为游玩而设计，为清晰而构建。' : 'Designed for play. Built for clarity.'}
        </div>
        <div class="footer-links">
          <a href="mailto:hello@example.com">{isZh ? '邮箱' : 'Email'}</a>
          <a href="https://github.com/Jadey0804" target="_blank" rel="noreferrer">GitHub</a>
          <span>© {year}</span>
        </div>
      </footer>
    </div>

    <script is:inline>
      const toggle = document.querySelector('[data-nav-toggle]');
      const nav = document.querySelector('[data-site-nav]');
      const header = document.querySelector('[data-site-header]');

      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav?.classList.toggle('is-open', !open);
      });

      nav?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          toggle?.setAttribute('aria-expanded', 'false');
          nav.classList.remove('is-open');
        });
      });

      const setHeaderState = () => header?.classList.toggle('is-scrolled', window.scrollY > 18);
      setHeaderState();
      window.addEventListener('scroll', setHeaderState, { passive: true });

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }),
          { threshold: 0.12 },
        );
        document.querySelectorAll('[data-reveal]').forEach((element) => observer.observe(element));
      } else {
        document.querySelectorAll('[data-reveal]').forEach((element) => element.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
